{
  "expo": {
    "name": "StretchGate",
    "slug": "stretchgate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "stretchgate",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#B3E8DF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.zorockz.Yoga",
      "buildNumber": "1",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "StretchGate sends reminders to stretch and alerts when your timed unlocks expire."
      }
    },
    "android": {},
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      ["expo-router"],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "iosDisplayInForeground": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
